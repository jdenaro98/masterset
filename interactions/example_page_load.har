            "text": "{\"errors\":[],\"results\":[{\"categoryId\":1,\"catalogGroupId\":1,\"categoryName\":\"Magic\",\"displayName\":\"Magic: The Gathering\",\"urlName\":\"magic-the-gathering\",\"categoryDescription\":\"Ignite your Planeswalker spark with Magic: The Gathering, the original trading card game designed by Richard Garfield, PhD! Buy the latest sets, MTG cards and singles, booster packs and expansions, Commander precons, and more.\",\"categoryPageTitle\":\"TCGplayer - Buy Magic: The Gathering Cards, Singles, and Set\",\"mpCanSearch\":true},{\"categoryId\":2,\"catalogGroupId\":1,\"categoryName\":\"YuGiOh\",\"displayName\":\"YuGiOh\",\"urlName\":\"yugioh\",\"categoryDescription\":\"It's time to duel! If you believe in the heart of the cards, you can shop thousands of sellers and buy Yu-Gi-Oh! cards and singles, booster packs, Structure Decks, dueling accessories, and more from the latest sets!\",\"categoryPageTitle\":\"TCGplayer - Buy YuGiOh TCG Cards, Singles, and Set\",\"mpCanSearch\":true},{\"categoryId\":3,\"catalogGroupId\":1,\"categoryName\":\"Pokemon\",\"displayName\":\"Pokemon\",\"urlName\":\"pokemon\",\"categoryDescription\":\"Trainers, your Pokémon adventure starts here! Whether you're a champ in the making or trying to catch 'em all from the latest sets, browse and buy Pokémon cards, booster boxes, Elite Trainer Boxes, and card packs at the best prices from thousands of sellers.\",\"categoryPageTitle\":\"TCGplayer - Buy Pokémon TCG Cards, Singles, and Pack\",\"mpCanSearch\":true},{\"categoryId\":13,\"catalogGroupId\":1,\"categoryName\":\"WoW\",\"displayName\":\"WoW\",\"urlName\":\"wow\",\"categoryDescription\":\"Join the Alliance or the Horde and fight for the fate of Azeroth! Shop thousands of sellers for the best prices on World of Warcraft TCG cards, booster boxes, raid decks, and more.\",\"categoryPageTitle\":\"TCGplayer - Buy World of Warcraft TCG cards, booster boxes, raid decks, and more\",\"mpCanSearch\":true},{\"categoryId\":16,\"catalogGroupId\":1,\"categoryName\":\"Cardfight Vanguard\",\"displayName\":\"Cardfight Vanguard\",\"urlName\":\"cardfight-vanguard\",\"categoryDescription\":\"Prove you're the greatest cardfighter by powering up your vanguard and leading your units to victory! Buy Cardfight!! Vanguard cards, Starter and Trial Decks, booster boxes and more.\",\"categoryPageTitle\":\"TCGplayer - Buy Cardfight!! Vanguard Cards, Singles, and Set\",\"mpCanSearch\":true},{\"categoryId\":17,\"catalogGroupId\":1,\"categoryName\":\"Force of Will\",\"displayName\":\"Force of Will\",\"urlName\":\"force-of-will\",\"categoryDescription\":\"Summon resonators, play chants, and join the fight with your J-Ruler in this exciting fantasy card game! Shop thousands of sellers for the best prices on Force of Will cards, booster boxes, starter decks, and more.\",\"categoryPageTitle\":\"Shop tcgplayer for the best prices on Force of Will cards, booster boxes, starter decks, and more\",\"mpCanSearch\":true},{\"categoryId\":18,\"catalogGroupId\":1,\"categoryName\":\"Dice Masters\",\"displayName\":\"Dice Masters\",\"urlName\":\"dice-masters\",\"categoryDescription\":\"Assemble the perfect team of heroes and villains from Marvel, DC, D&D, and other properties! Shop thousands of sellers for the best prices on Dice Masters cards, packs, and sets.\",\"categoryPageTitle\":\"TCGplayer - Buy Dice Masters cards, packs, and set\",\"mpCanSearch\":true},{\"categoryId\":19,\"catalogGroupId\":1,\"categoryName\":\"Future Card BuddyFight\",\"displayName\":\"Future Card BuddyFight\",\"urlName\":\"future-card-buddyfight\",\"categoryDescription\":\"Raise the flag! Call monsters, cast spells, equip items, and charge to victory side-by-side with your buddy. Shop thousands of sellers for the best prices on Future Card Buddyfight cards, booster boxes, Trial Decks, and more.\",\"categoryPageTitle\":\"TCGplayer - Buy Future Card Buddyfight cards, booster boxes, Trial Decks, and more\",\"mpCanSearch\":true},{\"categoryId\":20,\"catalogGroupId\":1,\"categoryName\":\"Weiss Schwarz\",\"displayName\":\"Weiss Schwarz\",\"urlName\":\"weiss-schwarz\",\"categoryDescription\":\"Take the stage and relive climactic moments with your favorite characters from anime, manga, and video games! Buy Weiss Schwarz cards and singles, booster boxes, and more.\",\"categoryPageTitle\":\"TCGplayer - Buy Weiss Schwarz Cards, Singles, and Set\",\"mpCanSearch\":true},{\"categoryId\":23,\"catalogGroupId\":1,\"categoryName\":\"Dragon Ball Z TCG\",\"displayName\":\"Dragon Ball Z TCG\",\"urlName\":\"dragon-ball-z-tcg\",\"categoryDescription\":\"Increase your power level to WAY over 9000 in the Dragon Ball Z TCG by Panini! Shop thousands of sellers for the best prices on Dragon Ball Z cards, booster boxes, starter decks, and more.\",\"categoryPageTitle\":\"TCGplayer - Buy Dragon Ball Z cards, booster boxes, and starter deck\",\"mpCanSearch\":true},{\"categoryId\":24,\"catalogGroupId\":1,\"categoryName\":\"Final Fantasy TCG\",\"displayName\":\"Final Fantasy TCG\",\"urlName\":\"final-fantasy-tcg\",\"categoryDescription\":\"Build your dream team of heroes, villains, and monsters from across every Final Fantasy universe! Shop thousands of sellers for the best prices on Final Fantasy TCG cards, booster boxes, starter sets, and more.\",\"categoryPageTitle\":\"TCGplayer - Buy Final Fantasy TCG cards, booster boxes, starter sets, and more\",\"mpCanSearch\":true},{\"categoryId\":25,\"catalogGroupId\":1,\"categoryName\":\"UniVersus\",\"displayName\":\"UniVersus\",\"urlName\":\"universus\",\"categoryDescription\":\"Competitors from multiple universes face off one-on-one in the Universal Fighting System! Shop thousands of sellers for the best prices on UniVersus cards, booster boxes, deck boxes, and more.\",\"categoryPageTitle\":\"TCGplayer - Buy UniVersus cards, booster boxes, deck boxes, and more\",\"mpCanSearch\":true},{\"categoryId\":26,\"catalogGroupId\":1,\"categoryName\":\"Star Wars Destiny\",\"displayName\":\"Star Wars: Destiny\",\"urlNam