{
  "name": "masterset",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  // Provides a browser-accessible desktop (noVNC on port 6080) so Electron can
  // render identically on both Mac and Windows without any host display server.
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/masterset,type=bind,consistency=cached",
  "workspaceFolder": "/workspaces/masterset",
  "features": {
    "ghcr.io/devcontainers/features/desktop-lite:1": {
      "password": "vscode",
      "webPort": 6080,
      "resolution": "1920x1080"
    }
  },
  // Electron requires extra shared memory to avoid GPU process crashes.
  // Wake the Ubuntu WSL distro on Windows so Docker can reach its socket for the Wayland bind-mount.
  "initializeCommand": { "windows": "wsl -d Ubuntu echo ready" },
  "runArgs": ["--shm-size=1g", "--security-opt", "seccomp=unconfined"],
  // Isolate node_modules inside a Docker volume so Linux-compiled native modules
  // (node-pty) don't overwrite the host's Windows/macOS binaries.
  "mounts": [
    "source=masterset-node_modules,target=${containerWorkspaceFolder}/node_modules,type=volume"
  ],
  "forwardPorts": [6080],
  "portsAttributes": {
    "6080": {
      "label": "Desktop",
      "onAutoForward": "openBrowser"
    }
  },
  // desktop-lite sets DISPLAY=:1 and starts VNC automatically on container start.
  "remoteEnv": {
    "DISPLAY": ":1"
  },
  // Install all dependencies on first container create.
  // `npm ci` triggers the postinstall electron-rebuild for node-pty (Linux).
  "postCreateCommand": "sudo chown -R node node_modules && npm ci && node node_modules/electron/install.js && pip install -r requirements.txt && playwright install chromium && sudo chown root:root node_modules/electron/dist/chrome-sandbox && sudo chmod 4755 node_modules/electron/dist/chrome-sandbox",
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/usr/bin/python3",
        "terminal.integrated.defaultProfile.linux": "bash"
      },
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff",
        "dbaeumer.vscode-eslint"
      ]
    }
  }
}
